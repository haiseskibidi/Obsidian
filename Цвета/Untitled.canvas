{
	"nodes":[
		{"id":"904f3530a3d4a3ab","type":"text","text":"<html>\n<body>\n<div class=\"color-card\" style=\"\n    /* === 1. МЕНЯЙ ЦВЕТА ТОЛЬКО ЗДЕСЬ === */\n    --bg: #F4C2C2; \n    --text: #800020;\n\n    /* Стили карточки под Excalidraw */\n    background-color: var(--bg);\n    color: var(--text);\n    padding: 30px 24px;\n    border-radius: 32px;\n    border: 2px solid var(--text);\n    width: 280px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    gap: 24px;\n    text-align: center;\n    box-sizing: border-box;\n    margin: auto;\n\n    <style>\n        @import url('https://fonts.cdnfonts.com/css/virgil');\n        .color-card, .color-card * {\n            font-family: 'Virgil', 'Comic Sans MS', cursive !important;\n        }\n    </style>\n\n    <div style=\"font-size: 28px; font-weight: 500; line-height: 1.2; text-transform: uppercase;\">\n        ЗАГОЛОВОК ИНТЕРФЕЙСА\n    </div>\n\n    <div onclick=\"navigator.clipboard.writeText(this.closest('.color-card').style.getPropertyValue('--bg').trim()); alert('Скопирован фон!')\" \n         style=\"font-size: 26px; cursor: pointer; user-select: none; font-weight: 500;\">\n        #f4c2c2\n    </div>\n\n    <div onclick=\"navigator.clipboard.writeText(this.closest('.color-card').style.getPropertyValue('--text').trim()); alert('Скопирован текст!')\" \n         style=\"\n            background-color: var(--text);\n            color: var(--bg);\n            padding: 8px 24px;\n            border-radius: 16px;\n            font-size: 26px;\n            cursor: pointer;\n            user-select: none;\n            width: 80%;\n            display: inline-block;\n         \">\n        #800020\n    </div>\n</div>\n</body>\n</html>","x":-340,"y":-500,"width":505,"height":1380}
	],
	"edges":[]
}