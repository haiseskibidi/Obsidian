{
	"nodes":[
		{"id":"371c61bdb1cc8b6f","x":-420,"y":-380,"width":250,"height":411,"type":"text","text":"<iframe srcdoc=\"\n<!DOCTYPE html>\n<html>\n<head>\n    <style>\n        @import url('https://fonts.cdnfonts.com/css/virgil');\n        body { margin: 0; padding: 10px; display: flex; justify-content: center; align-items: center; background: transparent; }\n        .color-card {\n            /* === МЕНЯЙ ЦВЕТА ТОЛЬКО ЗДЕСЬ === */\n            --bg: #F4C2C2; \n            --text: #800020;\n\n            background-color: var(--bg);\n            color: var(--text);\n            padding: 30px 24px;\n            border-radius: 32px;\n            border: 2px solid var(--text);\n            width: 260px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 24px;\n            text-align: center;\n            box-sizing: border-box;\n            font-family: 'Virgil', 'Comic Sans MS', cursive;\n        }\n        .title { font-size: 26px; font-weight: bold; text-transform: uppercase; line-height: 1.2; }\n        .hex-code { font-size: 24px; cursor: pointer; user-select: none; font-weight: 500; }\n        .btn {\n            background-color: var(--text);\n            color: var(--bg);\n            padding: 8px 24px;\n            border-radius: 16px;\n            font-size: 24px;\n            cursor: pointer;\n            user-select: none;\n            width: 80%;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"color-card\">\n        <div class=\"title\">ЗАГОЛОВОК ИНТЕРФЕЙСА</div>\n        <div class=\"hex-code\" onclick=\"navigator.clipboard.writeText('#F4C2C2'); alert('Скопирован фон: #F4C2C2')\">#f4c2c2</div>\n        <div class=\"btn\" onclick=\"navigator.clipboard.writeText('#800020'); alert('Скопирован текст: #800020')\">#800020</div>\n    </div>\n</body>\n</html>\n\" style=\"width: 310px; height: 360px; border: none; background: transparent;\"></iframe>"}
	],
	"edges":[]
}